<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/button_primary_fall">

        <Button
            android:id="@+id/attendance_records_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="← Back"
            android:textColor="@android:color/white"
            android:background="@android:color/transparent"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Attendance Records"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center" />

        <Button
            android:id="@+id/attendance_records_refresh_btn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="🔄"
            android:textColor="@android:color/white"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- Event Name -->
    <TextView
        android:id="@+id/attendance_records_event_name_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/background_color" />
    
    <!-- Status Text -->
    <TextView
        android:id="@+id/attendance_records_status_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading attendance records..."
        android:textSize="14sp"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@color/text_secondary_fall" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/attendance_records_empty_state_tv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No attendance records yet.\n\nStart a session and have students check in to see records here!"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="32dp"
        android:textColor="@color/text_secondary_fall"
        android:visibility="gone" />

    <!-- Records List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/attendance_records_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp" />

</LinearLayout>
