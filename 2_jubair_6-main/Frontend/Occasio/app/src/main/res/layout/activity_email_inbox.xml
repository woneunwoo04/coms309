<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">
    
    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email Inbox"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_fall"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/email_inbox_refresh_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refresh"
            android:textColor="@color/text_primary_fall"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/email_inbox_back_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="@color/text_primary_fall"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/email_inbox_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <!-- Empty View -->
    <TextView
        android:id="@+id/email_inbox_empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No emails yet"
        android:textSize="18sp"
        android:textColor="@color/text_secondary_fall"
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:visibility="gone" />

    </LinearLayout>
    
    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
