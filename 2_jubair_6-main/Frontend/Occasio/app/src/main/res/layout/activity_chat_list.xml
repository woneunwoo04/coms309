<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/primary_fall"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Messages"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_fall"
            android:gravity="center" />
        
        <!-- Hidden back button for compatibility -->
        <Button
            android:id="@+id/back_button"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ScrollView for the content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Friends Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_style"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/friends_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 Friends"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_fall"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/friends_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <!-- Empty state for friends -->
                <LinearLayout
                    android:id="@+id/friends_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No messages"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary_fall"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/friends_view_friends_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Friends List"
                        android:textSize="14sp"
                        android:background="@drawable/button_primary_fall"
                        android:textColor="@color/text_on_fall"
                        android:padding="12dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Groups Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_style"
                android:padding="16dp">

                <TextView
                    android:id="@+id/groups_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 Groups"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_fall"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/groups_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <!-- Empty state for groups -->
                <LinearLayout
                    android:id="@+id/groups_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No messages"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary_fall"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/groups_view_groups_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Groups List"
                        android:textSize="14sp"
                android:background="@drawable/button_primary_fall"
                android:textColor="@color/text_on_fall"
                        android:padding="12dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    
    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
