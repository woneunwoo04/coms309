<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/org_rewards_back_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/button_secondary_fall"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🏆 Organization Rewards"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:gravity="center" />

        </LinearLayout>

        <!-- Welcome Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background_fall"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Organization Rewards Dashboard"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track your organization's impact and engagement"
                android:textSize="16sp"
                android:textColor="@color/text_secondary_fall"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/org_rewards_status_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitor your organization's performance!"
                android:textSize="14sp"
                android:textColor="@color/text_secondary_fall"
                android:gravity="center" />

        </LinearLayout>

        <!-- Organization Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_background_fall"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_fall" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Events Created"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_fall" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_fall" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Attendees"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_fall" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/org_rewards_manage_vouchers_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Manage Vouchers"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/button_primary_fall"
                android:padding="16dp" />

        </LinearLayout>

        <!-- Rewards Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Organization Metrics"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:layout_marginBottom="16dp" />

            <!-- Event Creation Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_fall"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Event Creation"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create engaging events for your community"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Impact: Builds community engagement"
                    android:textSize="14sp"
                    android:textColor="@color/accent_fall" />

            </LinearLayout>

            <!-- Attendance Tracking Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_fall"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👥 Attendance Tracking"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitor event attendance and engagement"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Impact: Measures event success"
                    android:textSize="14sp"
                    android:textColor="@color/accent_fall" />

            </LinearLayout>

            <!-- Community Building Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background_fall"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤝 Community Building"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Foster connections and relationships"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_fall"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Impact: Strengthens campus community"
                    android:textSize="14sp"
                    android:textColor="@color/accent_fall" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar_organization"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
