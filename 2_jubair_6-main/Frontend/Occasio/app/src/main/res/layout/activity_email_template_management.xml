<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Email Templates"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_fall"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/email_templates_create_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Template"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_fall"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/email_templates_send_email_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Send Email"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/email_templates_status_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading templates..."
        android:textSize="14sp"
        android:textColor="@color/text_secondary_fall"
        android:layout_marginBottom="8dp" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/email_templates_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/email_templates_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No templates found"
            android:textSize="18sp"
            android:textColor="@color/text_secondary_fall"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your first email template"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_fall" />
    </LinearLayout>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/email_templates_refresh_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Refresh"
            android:textColor="@color/text_primary_fall"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/email_templates_back_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back"
            android:textColor="@color/text_primary_fall"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    </LinearLayout>
    
    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar_organization"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
