<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">
    
    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_fall"
        android:padding="16dp"
        android:gravity="center"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notifications"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_fall"
            android:gravity="center" />
    </LinearLayout>

    <!-- Action Buttons Row -->
    <LinearLayout
        android:id="@+id/notification_action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/mark_all_read_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark All as Read"
            android:background="@drawable/button_primary_fall"
            android:textColor="@color/text_on_fall"
            android:textSize="14sp"
            android:padding="12dp" />

    </LinearLayout>

    <!-- Selection Mode Action Bar -->
    <LinearLayout
        android:id="@+id/notification_selection_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_fall"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/notification_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 selected"
            android:textColor="@color/text_on_fall"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical" />

        <Button
            android:id="@+id/select_all_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:background="@drawable/button_secondary_fall"
            android:textColor="@color/text_primary_fall"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/delete_selected_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️ Delete"
            android:background="@drawable/button_delete_fall"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/cancel_selection_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:background="@drawable/button_secondary_fall"
            android:textColor="@color/text_primary_fall"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notification_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <!-- Empty View -->
    <TextView
        android:id="@+id/notification_empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No notifications yet"
        android:textSize="18sp"
        android:textColor="@color/text_secondary_fall"
        android:gravity="center"
        android:layout_marginTop="50dp"
        android:visibility="gone" />

    </LinearLayout>
    
    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
