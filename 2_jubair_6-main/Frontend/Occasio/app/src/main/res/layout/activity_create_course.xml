<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/create_course_back_btn"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="← Back"
                android:textColor="@color/text_primary_fall"
                android:background="@android:color/transparent"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create New Course"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:gravity="center" />

        </LinearLayout>

        <!-- Course Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course Name *"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/create_course_name_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., COMS 309 - Software Development"
            android:padding="16dp"
            android:background="@drawable/card_style"
            android:layout_marginBottom="16dp" />

        <!-- Location Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location (Optional)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/create_course_location_status_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location Status"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/create_course_use_location_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Use Current Location"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/create_course_latitude_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/card_style"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/create_course_longitude_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/card_style"
            android:layout_marginBottom="8dp" />

        <!-- Radius Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Geofence Radius *"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose the radius in meters for the attendance geofence.\n\nSuggested values:\n• Small room: 10-20m\n• Large room: 20-50m\n• Building: 50-100m\n• Campus area: 100-200m"
            android:textSize="12sp"
            android:textColor="@color/text_secondary_fall"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/create_course_radius_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter radius in meters (e.g., 50, 100)"
            android:inputType="numberDecimal"
            android:padding="16dp"
            android:background="@drawable/card_style"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tip: Larger radius provides more flexibility for GPS accuracy, but allows check-in from further away."
            android:textSize="11sp"
            android:textStyle="italic"
            android:textColor="@color/text_secondary_fall"
            android:layout_marginBottom="16dp" />

        <!-- WiFi Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WiFi SSID (Optional)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/create_course_use_wifi_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📶 Use Current WiFi"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/create_course_wifi_ssid_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WiFi Network Name"
            android:padding="16dp"
            android:background="@drawable/card_style"
            android:layout_marginBottom="24dp" />

        <!-- Create Button -->
        <Button
            android:id="@+id/create_course_create_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Course"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_fall"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="16dp" />

    </LinearLayout>

</ScrollView>
