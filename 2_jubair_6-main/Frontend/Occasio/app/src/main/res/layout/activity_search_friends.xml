<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/search_friends_back_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👥 Search Friends"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_fall"
            android:gravity="center" />

    </LinearLayout>

    <!-- Search Input Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background_fall"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/search_friends_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter username or email..."
                android:textSize="16sp"
                android:textColor="@color/text_primary_fall"
                android:textColorHint="@color/text_secondary_fall"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/search_friends_search_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_fall"
                android:background="@drawable/button_primary_fall"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/search_friends_status_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type a username or email and press Enter or Search..."
            android:textSize="14sp"
            android:textColor="@color/text_secondary_fall"
            android:gravity="center" />

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/search_friends_my_friends_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👫 My Friends"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_fall"
            android:padding="16dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/search_friends_requests_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📬 Requests"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:padding="16dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Search Results -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/search_friends_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />

    </ScrollView>

</LinearLayout>
