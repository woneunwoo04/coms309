<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_fall"
    android:padding="24dp"
    android:gravity="center">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btn_back_to_login"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:layout_marginEnd="16dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔐 Forgot Password"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_fall"
            android:gravity="center" />

    </LinearLayout>

    <!-- Instructions -->
    <TextView
        android:id="@+id/tv_forgot_password_instructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter your email address and we'll send you instructions to reset your password."
        android:textSize="16sp"
        android:textColor="@color/text_secondary_fall"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"
        android:lineSpacingExtra="4dp" />

    <!-- Email Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/accent_fall"
        app:hintTextColor="@color/accent_fall"
        app:startIconDrawable="@drawable/ic_email"
        app:startIconTint="@color/accent_fall">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_email_forgot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/email_hint"
            android:inputType="textEmailAddress"
            android:textColor="@color/text_primary_fall"
            android:textColorHint="@color/text_secondary_fall" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Send Reset Link Button -->
    <Button
        android:id="@+id/btn_send_request"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Reset Link"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_on_fall"
        android:background="@drawable/button_primary_fall"
        android:padding="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Additional Help -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remember your password?"
        android:textSize="14sp"
        android:textColor="@color/text_secondary_fall"
        android:textAlignment="center"
        android:layout_marginTop="16dp" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back_to_login_from_forgot"
        android:textSize="14sp"
        android:textColor="@color/accent_fall"
        android:background="@android:color/transparent"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

</LinearLayout>
