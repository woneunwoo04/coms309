<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_color">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👥 Search Groups"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="@color/text_primary_fall"
        android:shadowColor="@color/fall_brown"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search for groups and join them"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"
        android:textColor="@color/text_secondary_fall" />

    <!-- Search Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_style"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/search_groups_et"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search by group name..."
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edit_text_background"
            android:textColorHint="@color/text_secondary_fall" />

        <Button
            android:id="@+id/my_groups_nav_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 View My Groups"
            android:layout_marginBottom="8dp"
            android:background="@drawable/button_secondary_fall"
            android:textColor="@color/text_on_fall"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp" />

    </LinearLayout>

    <!-- Results Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/card_style"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search Results"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:textColor="@color/text_primary_fall" />

        <ProgressBar
            android:id="@+id/search_progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/no_results_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No groups found"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_secondary_fall" />

        <RecyclerView
            android:id="@+id/groups_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
