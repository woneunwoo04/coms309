<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Username -->
        <TextView
            android:id="@+id/event_feedback_item_username_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@username"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <!-- Rating -->
        <RatingBar
            android:id="@+id/event_feedback_item_rating_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="5"
            android:stepSize="1.0"
            android:isIndicator="true"
            android:layout_marginBottom="8dp"
            android:progressTint="@color/rating_pink"
            android:progressBackgroundTint="@color/rating_pink_light"
            android:secondaryProgressTint="@color/rating_pink" />

        <!-- Comment -->
        <TextView
            android:id="@+id/event_feedback_item_comment_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comment"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Date -->
        <TextView
            android:id="@+id/event_feedback_item_date_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</androidx.cardview.widget.CardView>

