<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fadeScrollbars="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/messaging_back_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/button_secondary_fall"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💬 Messages"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:gravity="center" />

        </LinearLayout>

        <!-- Welcome Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background_fall"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messaging Center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay connected with your friends and event attendees"
                android:textSize="16sp"
                android:textColor="@color/text_secondary_fall"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/messaging_status_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading your conversations..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary_fall"
                android:gravity="center" />

        </LinearLayout>

        <!-- Quick Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/messaging_group_chat_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="➕ Create New Chat"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_fall"
                android:background="@drawable/button_primary_fall"
                android:padding="16dp" />

        </LinearLayout>

        <!-- Friend Chats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/friends_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 Friend Chats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/friends_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:minHeight="200dp" />

            <LinearLayout
                android:id="@+id/friends_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No friend chats yet"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary_fall"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Group Chats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/groups_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 Group Chats"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_fall"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/groups_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:minHeight="200dp"
                android:overScrollMode="never"
                android:clipToPadding="false" />

            <LinearLayout
                android:id="@+id/groups_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No group chats yet"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary_fall"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

    <!-- Bottom Navigation Bar -->
    <include
        layout="@layout/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
