<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_color"
    android:gravity="center">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👥 Groups"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textColor="@color/text_primary_fall"
        android:shadowColor="@color/fall_brown"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose what you want to do with groups"
        android:textSize="16sp"
        android:layout_marginBottom="40dp"
        android:textColor="@color/text_secondary_fall" />

    <!-- Action Cards Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_style"
        android:padding="24dp"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/search_groups_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Search Groups"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_primary_fall"
            android:textColor="@color/text_on_fall"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp" />

        <Button
            android:id="@+id/my_groups_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👥 My Groups"
            android:layout_marginBottom="16dp"
            android:background="@drawable/button_secondary_fall"
            android:textColor="@color/text_on_fall"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="16dp" />

    </LinearLayout>

</LinearLayout>
