<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_fall"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_fall"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <!-- Top Row: Title and Refresh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/org_calendar_header_tv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Organization Calendar"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_fall"
                android:gravity="center" />

            <Button
                android:id="@+id/org_calendar_refresh_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🔄"
                android:textSize="18sp"
                android:textColor="@color/text_on_fall"
                android:background="@drawable/button_accent_fall"
                android:padding="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Calendar Events List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/org_calendar_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- Back Button -->
    <Button
        android:id="@+id/org_calendar_back_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Back"
        android:textColor="@color/text_on_fall"
        android:background="@drawable/button_accent_fall"
        android:padding="12dp"
        android:minHeight="48dp" />

</LinearLayout>
