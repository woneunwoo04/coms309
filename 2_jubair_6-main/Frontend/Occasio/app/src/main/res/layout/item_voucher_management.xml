<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background_fall"
    android:padding="20dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/voucher_mgmt_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voucher Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_fall" />

        <TextView
            android:id="@+id/voucher_mgmt_active_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Active"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="4dp"
            android:background="@drawable/button_secondary_fall"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <TextView
        android:id="@+id/voucher_mgmt_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voucher description"
        android:textSize="14sp"
        android:textColor="@color/text_secondary_fall"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/voucher_mgmt_cost_points"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="500 points"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/accent_fall"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/voucher_mgmt_edit_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ Edit"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/voucher_mgmt_toggle_active_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Activate"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_fall"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/voucher_mgmt_delete_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑️ Delete"
            android:textSize="12sp"
            android:textColor="@android:color/white"
            android:background="@drawable/button_secondary_fall"
            android:padding="8dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</LinearLayout>

